# breach-sim — configuration live
# Copier ce fichier en .env et remplir les valeurs
# cp .env.template .env

BREACH_LIVE=1
BREACH_INSTANCE=1
BREACH_LAB_TYPE=classic

# OPNsense
BREACH_OPNSENSE_IP=192.168.1.1
BREACH_OPNSENSE_PORT=4443
BREACH_OPNSENSE_API_KEY=
BREACH_OPNSENSE_API_SECRET=
BREACH_OPNSENSE_VERIFY_TLS=0

# CrowdSec LAPI (tourne sur OPNsense)
BREACH_CROWDSEC_IP=192.168.1.1
BREACH_CROWDSEC_API_KEY=

# VMs
BREACH_SRV_WEB_IP=192.168.1.10
BREACH_SRV_DB_IP=192.168.21.10
BREACH_INFECTED_IP=192.168.21.20

# SSH
BREACH_SSH_USER=breach

# T-Pot
BREACH_TPOT_IP=127.0.0.1
BREACH_TPOT_ES_PORT=64298
BREACH_TPOT_ES_USER=
BREACH_TPOT_ES_PASSWORD=

# MaxMind GeoLite2 — https://www.maxmind.com/en/geolite2/signup
# Télécharger la base :
#   curl -L "https://download.maxmind.com/app/geoip_download?edition_id=GeoLite2-City&license_key=VOTRE_CLE&suffix=tar.gz" \
#     | tar xz --strip-components=1 -C /srv/breach-sim/app/backend/ "*/GeoLite2-City.mmdb"
BREACH_MAXMIND_ACCOUNT_ID=
BREACH_MAXMIND_LICENSE_KEY=
BREACH_GEOIP_DB=/srv/breach-sim/app/backend/GeoLite2-City.mmdb
