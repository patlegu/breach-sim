    </item>
    <item uuid="5de26ee1-eff7-4514-bc63-ba05f7355ab7">
      <tunable>net.inet.ip.sourceroute</tunable>
      <value>default</value>
      <descr>Source routing is disabled</descr>
    </item>
    <item uuid="c06b3f11-02f9-436e-895f-f8f1c0761ada">
      <tunable>net.inet.ip.accept_sourceroute</tunable>
      <value>default</value>
      <descr>Accept source routing disabled</descr>
    </item>
    <item uuid="e3aeef60-b194-480b-9c20-d720c96745b4">
      <tunable>net.inet.icmp.log_redirect</tunable>
      <value>default</value>
      <descr>Disable ICMP redirect logging</descr>
    </item>
    <item uuid="4430971c-e8c9-43c6-a21d-99f4ea397431">
      <tunable>net.inet.tcp.drop_synfin</tunable>
      <value>default</value>
      <descr>Drop SYN-FIN packets</descr>
    </item>
    <item uuid="620ba394-78b3-469e-8690-0bfcc03d165e">
      <tunable>net.inet6.ip6.redirect</tunable>
      <value>default</value>
      <descr>Enable sending IPv6 redirects</descr>
    </item>
    <item uuid="e522ebcb-aced-41ee-bc26-acfa55c4198d">
      <tunable>net.inet6.ip6.use_tempaddr</tunable>
      <value>default</value>
      <descr>Enable privacy settings for IPv6 (RFC 4941)</descr>
    </item>
    <item uuid="ab35b0e7-c71e-4bb9-932b-48042db2555a">
      <tunable>net.inet6.ip6.prefer_tempaddr</tunable>
