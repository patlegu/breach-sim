<opnsense>
  <theme>opnsense</theme>
  <sysctl version="1.0.0">
    <item uuid="a3b33a69-8ef2-440c-983c-a7e25c01df26">
      <tunable>vfs.read_max</tunable>
      <value>default</value>
      <descr>Increase UFS read-ahead speeds to match the state of hard drives and NCQ.</descr>
    </item>
    <item uuid="8e49e46b-4374-46fb-b656-008a049fe5c3">
      <tunable>net.inet.ip.portrange.first</tunable>
      <value>default</value>
      <descr>Set the ephemeral port range to be lower.</descr>
    </item>
    <item uuid="13ad44dd-47ae-4654-b12a-d12661287f1f">
      <tunable>net.inet.tcp.blackhole</tunable>
      <value>default</value>
      <descr>Drop packets to closed TCP ports without returning a RST</descr>
    </item>
    <item uuid="35fe615d-a672-47b7-9b6c-35b8e1d5b7b9">
      <tunable>net.inet.udp.blackhole</tunable>
      <value>default</value>
      <descr>Do not send ICMP port unreachable messages for closed UDP ports</descr>
    </item>
    <item uuid="a681f9fd-697e-48cb-a64b-ac48e2c18cd1">
      <tunable>net.inet.ip.random_id</tunable>
      <value>default</value>
